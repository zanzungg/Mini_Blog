APP_PORT=3000

# Database (Prisma)
DATABASE_URL=postgresql://your_database_user:your_database_password@localhost:5432/your_database_name?schema=public

# JWT Secret Key
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRES_IN_SECONDS=604800

# CORS Allowed Origins
CORS_ORIGIN=http://localhost:3000,http://your-frontend-domain.com
CORS_CREDENTIALS=false
TRUST_PROXY=false
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# Swagger
SWAGGER_ENABLED=true